# 홈 대시보드 폴링 주기(초)
HOME_STREAM_INTERVAL_SEC=1.0

# 실시간 마크 스트림 vs 1h 차트 폴링
CHART_POLL_SEC=90

# 청산 맵 (backtest liq_cache_builder 와 동일: window=400, min_bars=50)
# Redis·메모리에는 window 의 2배(기본 800봉)만 유지
LIQ_WINDOW=400
LIQ_RETAIN_BARS=800
LIQ_MIN_BARS=50
LIQ_REFRESH_SEC=120
LIQ_SYMBOLS=BTCUSDT,ETHUSDT
# 캐시가 비어 있을 때 첫 요청에서 REST로 채움 (false면 캐시만, cold 시 503)
LIQ_ON_DEMAND_FETCH=true

# Redis (비우면 메모리 캐시만 사용)
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=forwardtest:v1
REDIS_TTL_SEC=7200

# Binance Futures 마크 WS (선택)
# BINANCE_WS_MIN_RECONNECT_SEC=3.0
